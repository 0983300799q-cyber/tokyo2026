<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>東京探索者 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
<style>
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Noto Serif TC',serif;background:#F5EFE6;color:#2C1A0E;line-height:1.6;padding:20px;}
  .container{max-width:800px;margin:0 auto;background:#fff;padding:30px;border-radius:15px;box-shadow:0 5px 20px rgba(0,0,0,0.1);}
  .day{margin-bottom:30px;border-bottom:1px solid #C8B89A;padding-bottom:20px;}
  h1{text-align:center;color:#6B4C3B;margin-bottom:30px;}
  h2{color:#A0785A;margin-bottom:15px;}
  .event{display:flex;gap:15px;margin-bottom:10px;align-items:center;}
  .time{font-family:monospace;font-weight:bold;color:#8A7260;width:60px;}
  a{text-decoration:none;color:#B85C38;font-weight:600;}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const { useState } = React;

// 修正後的正確地圖語法
const mapsUrl = (name) => `https://www.google.com/maps/search/${encodeURIComponent(name + " 日本")}`;

function App() {
  const [data] = useState({
    title: "東京探索者 2026",
    days: [
      { date: "5/21", title: "抵達東京", events: [{time:"08:00", emoji:"✈️", name:"高雄國際機場"}] },
      { date: "5/22", title: "迪士尼樂園", events: [{time:"09:00", emoji:"🎡", name:"東京迪士尼樂園"}] }
    ]
  });

  return (
    <div className="container">
      <h1>{data.title}</h1>
      {data.days.map((day, i) => (
        <div key={i} className="day">
          <h2>Day {i+1} - {day.date} {day.title}</h2>
          {day.events.map((ev, j) => (
            <div key={j} className="event">
              <span className="time">{ev.time}</span>
              <span>{ev.emoji}</span>
              <a href={mapsUrl(ev.name)} target="_blank">{ev.name}</a>
            </div>
          ))}
        </div>
      ))}
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById("root"));
root.render(<App />);
</script>
</body>
</html>
